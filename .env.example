# Productive.io API credentials
# Generate a token at: Settings -> API integrations -> Generate new token
PRODUCTIVE_API_TOKEN=your_api_token_here

# Your organization ID (found in Productive URL or API settings)
PRODUCTIVE_ORG_ID=your_org_id_here

# Your person ID in Productive
# You can find this by running: python sync_time_entries.py --whoami
PRODUCTIVE_PERSON_ID=your_person_id_here

# Your office / subsidiary name in Productive (used to filter bookings)
# Run: python sync_time_entries.py --whoami  to verify it resolves
PRODUCTIVE_SUBSIDIARY_NAME=PDUS

# Country code for holiday calendar matching (ISO-style, e.g. US, HR, GB, DE)
# Run: python sync_time_entries.py --list-calendars  to see available calendars
PRODUCTIVE_COUNTRY_CODE=US
